  int target_id = -1;


  std::string target_frame;



  // ===============================
  // 메인 루프
  // ===============================

  rclcpp::Rate rate(10);


  while (rclcpp::ok()) {

    switch (state) {



      // ===============================
      // HOME 상태
      // ===============================
      case FSM::HOME_INIT: {

        // 로봇 팔을 home 위치로 이동
        arm.setNamedTarget("home");

        arm.move();


        // 그리퍼 열기
        operateGripper(node.get(), gripper, 0.019);


        // 다음 상태
        state = FSM::WAIT_MARKER;

        break;
      }



      // ===============================
      // 마커 탐색
      // ===============================
      case FSM::WAIT_MARKER: {

        // 마커 탐지 대기

        // 마커 발견되면
        // CENTER_ON_MARKER 상태로 이동

        break;
      }



      // ===============================
      // 마커 센터링
      // ===============================
      case FSM::CENTER_ON_MARKER: {

        // 카메라 기준 마커 위치 얻기

        // yaw pitch 계산

        // 관절을 조금씩 움직여서
        // 마커를 카메라 중앙으로 이동

        break;
      }



      // ===============================
      // 마커 접근
      // ===============================
      case FSM::APPROACH_CONTINUOUS: {

        // base_frame 기준 마커 위치 계산

        // end effector 목표 위치 계산

        // stepToward로 조금씩 접근

        break;
      }



      // ===============================
      // 물체 잡기
      // ===============================
      case FSM::GRASP: {

        // 그리퍼 닫기

        operateGripper(node.get(), gripper, 0.0);

        state = FSM::LIFT_HOME;

        break;
      }



      // ===============================
      // 물체 들어올리고 home
      // ===============================
