  arm.setMaxAccelerationScalingFactor(0.20);


  // planning 시간
  arm.setPlanningTime(3.0);


  // 위치 오차 허용
  arm.setGoalPositionTolerance(0.01);


  // 방향 오차 허용
  arm.setGoalOrientationTolerance(3.14);



  // ===============================
  // Gripper action client 생성
  // ===============================
