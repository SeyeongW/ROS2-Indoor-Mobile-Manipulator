  // ROS2 초기화
  rclcpp::init(argc, argv);


  // 노드 옵션
  rclcpp::NodeOptions opts;

  opts.automatically_declare_parameters_from_overrides(true);


  // 노드 생성
  auto node = std::make_shared<rclcpp::Node>("real_pick_node", opts);



  // 멀티스레드 executor
