#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import rclpy
from rclpy.node import Node
from ackermann_msgs.msg import AckermannDriveStamped


def clamp(value: float, low: float, high: float) -> float:
    return max(low, min(high, value))


class ForwardThenBrake(Node):
    """
    실행하면 자동으로:
    1) 0.1 m/s 로 직진
    2) 1초 유지
    3) 강하게 감속해서 정지
    """

    def __init__(self):
        super().__init__('forward_then_brake')

        # -----------------------------
        # 파라미터
        # -----------------------------
        self.declare_parameter('publish_topic', '/drive')
        self.declare_parameter('publish_rate_hz', 20.0)

        # 주행 프로파일
        self.declare_parameter('forward_speed_mps', 0.1)   # 10 cm/s
        self.declare_parameter('forward_time_sec', 2.0)    # 1초 전진
        self.declare_parameter('max_accel_mps2', 0.3)      # 출발 가속
        self.declare_parameter('brake_decel_mps2', 2.0)    # 급브레이크용 감속
        self.declare_parameter('max_steer_rad', 0.0)       # 직진

        self.publish_topic = self.get_parameter('publish_topic').value
        self.publish_rate_hz = float(self.get_parameter('publish_rate_hz').value)
        self.forward_speed_mps = float(self.get_parameter('forward_speed_mps').value)
        self.forward_time_sec = float(self.get_parameter('forward_time_sec').value)
        self.max_accel_mps2 = float(self.get_parameter('max_accel_mps2').value)
        self.brake_decel_mps2 = float(self.get_parameter('brake_decel_mps2').value)
        self.max_steer_rad = float(self.get_parameter('max_steer_rad').value)

        # -----------------------------
        # 상태
        # -----------------------------
        self.current_speed_cmd = 0.0
        self.current_steer_cmd = 0.0

        self.start_time = self.get_clock().now()
        self.finished = False

        # -----------------------------
        # publisher / timer
        # -----------------------------
        self.drive_pub = self.create_publisher(AckermannDriveStamped, self.publish_topic, 10)

        self.dt = 1.0 / self.publish_rate_hz
        self.timer = self.create_timer(self.dt, self.control_loop)

        self.get_logger().info('forward_then_brake started')
        self.get_logger().info(f'forward_speed_mps = {self.forward_speed_mps}')
        self.get_logger().info(f'forward_time_sec  = {self.forward_time_sec}')
        self.get_logger().info(f'brake_decel_mps2  = {self.brake_decel_mps2}')

    def seconds_since_start(self) -> float:
        return (self.get_clock().now() - self.start_time).nanoseconds * 1e-9

    def ramp_toward(self, current: float, target: float, accel_limit: float, decel_limit: float) -> float:
        if target > current:
            step = accel_limit * self.dt
            return min(current + step, target)
        else:
            step = decel_limit * self.dt
            return max(current - step, target)

    def publish_drive(self, speed: float, steer: float, accel: float = 0.0, jerk: float = 0.0):
        msg = AckermannDriveStamped()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.header.frame_id = 'base_link'

        msg.drive.steering_angle = float(steer)
        msg.drive.steering_angle_velocity = 0.0
        msg.drive.speed = float(speed)
        msg.drive.acceleration = float(accel)
        msg.drive.jerk = float(jerk)

        self.drive_pub.publish(msg)

    def control_loop(self):
        t = self.seconds_since_start()

        # 1단계: 1초 동안 0.1 m/s로 직진
        if t < self.forward_time_sec:
            desired_speed = self.forward_speed_mps
            desired_steer = 0.0
            accel_limit = self.max_accel_mps2
            decel_limit = self.brake_decel_mps2

        # 2단계: 그 이후 즉시 정지 목표 + 강한 감속
        else:
            desired_speed = 0.0
            desired_steer = 0.0
            accel_limit = self.max_accel_mps2
            decel_limit = self.brake_decel_mps2

        # 속도/조향 명령 갱신
        self.current_speed_cmd = self.ramp_toward(
            self.current_speed_cmd,
            desired_speed,
            accel_limit=accel_limit,
            decel_limit=decel_limit
        )
        self.current_steer_cmd = desired_steer

        self.current_speed_cmd = clamp(self.current_speed_cmd, 0.0, self.forward_speed_mps)

        # 가속도 부호
        signed_accel = accel_limit if desired_speed > self.current_speed_cmd else -decel_limit

        self.publish_drive(
            speed=self.current_speed_cmd,
            steer=self.current_steer_cmd,
            accel=signed_accel,
            jerk=0.0
        )

        # 완전히 멈췄으면 종료 메시지 1회 출력
        if (t >= self.forward_time_sec) and (self.current_speed_cmd <= 1e-4) and (not self.finished):
            self.finished = True
            self.get_logger().info('Forward-then-brake sequence finished. Vehicle stopped.')

    def stop_vehicle(self):
        # 종료 직전 정지 명령 여러 번 보내는 게 더 안전함
        for _ in range(5):
            self.publish_drive(0.0, 0.0, accel=0.0, jerk=0.0)


def main(args=None):
    rclpy.init(args=args)
    node = ForwardThenBrake()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.stop_vehicle()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()